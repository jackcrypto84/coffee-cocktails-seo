{
  "principles": [
    {
      "principle": "Originality over volume",
      "rule": "Ship fewer pages if needed, but every page must answer a sharper question or provide a more tested angle than generic AI content."
    },
    {
      "principle": "Three distinctive insights minimum",
      "rule": "Every article brief must force at least 3 non-generic insights from tasting notes, side-by-side tests, workflow logs, or service observations."
    },
    {
      "principle": "Programmatic with guardrails",
      "rule": "No template page should launch unless it can show real curation, useful comparison logic, and a meaningful related-article set."
    },
    {
      "principle": "Human verification where the cup or glass matters",
      "rule": "Recipes, tasting notes, gear performance claims, historical assertions, and safety guidance require firsthand testing or expert review before publish."
    },
    {
      "principle": "Maintainability first",
      "rule": "Use a small number of durable clusters and reusable templates instead of exploding taxonomy depth too early."
    }
  ],
